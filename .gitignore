## Ignore Visual Studio temporary files, build results, and
## files generated by popular Visual Studio add-ons.

# User-specific files
*.rsuser
*.suo
*.user
*.userosscache
*.sln.docstates

# Build results
[Dd]ebug/
[Rr]elease/
x64/
x86/
build/
bld/
[Bb]in/
[Oo]bj/
[Ll]og/

# .NET Core
project.lock.json
project.fragment.lock.json
artifacts/

# Visual Studio cache/options
.vs/

# Rider
.idea/

# VS Code
.vscode/

# Resharper
_ReSharper*/
*.DotSettings.user

# NuGet
*.nupkg
*.snupkg
packages/
.nuget/

# Publish output
publish/
*.publishproj

# Azure
PublishScripts/

# Test results
TestResults/
*.trx

# IIS Express
.vs/
*.vspscc
*.vssscc

# SQL Server files
*.mdf
*.ldf

# Windows image file caches
Thumbs.db
ehthumbs.db

# OS files
.DS_Store

# Logs
*.log

# Coverage
coverage/
*.coverage
*.coveragexml

# Entity Framework migrations (optional — remove if you track migrations)
# Migrations/

# DotNet CLI
.dotnet/

# Local settings
appsettings.Development.json